PORT=5000

# MongoDB Atlas 연결 문자열 (우선 사용). 비어 있거나 없으면 MONGO_URI → 그것도 없으면 아래 로컬 기본값
MongoDB_ATLAS_URI=

MONGO_URI=mongodb://127.0.0.1:27017/shopping_mall
JWT_SECRET=your-jwt-secret-here

# 포트원 REST API V2 — 주문 생성 시 결제 단건 조회·검증 (콘솔 > 연동 정보 > API Secret)
PORTONE_API_SECRET=
# 선택: 결제 건의 storeId까지 검증하려면 클라이언트 VITE_PORTONE_STORE_ID와 동일하게
# PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PORTONE_API_BASE=https://api.portone.io
